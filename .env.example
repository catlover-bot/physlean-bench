# Copy to .env and fill as needed.
# Never commit real secrets.

# Source repo configuration
PHYSLEAN_SOURCE_URL=https://github.com/leanprover-community/physlib.git
PHYSLEAN_SOURCE_COMMIT=

# Paths
PHYSLEAN_BENCH_ROOT=.
PHYSLEAN_BENCH_DATA_DIR=./data
PHYSLEAN_BENCH_OUTPUT_DIR=./outputs

# Evaluation backend placeholders
DEEPSEEK_PROVER_V2_ENDPOINT=
DEEPSEEK_PROVER_V2_API_KEY=
DEEPSEEK_PROVER_V2_MODEL_NAME=deepseek-prover-v2

# Runtime defaults
PHYSLEAN_BENCH_LOG_LEVEL=INFO
